# App
PORT=8080
JWT_SECRET=change_me
HMAC_SECRET=change_me_too
CLEAN_DB_ON_STARTUP=false

# Worker
WORKER_MAX_BATCH_SIZE=5000
WORKER_MIN_BACKOFF_MS=50
WORKER_MAX_BACKOFF_MS=1000

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=nubo
POSTGRES_PASSWORD=nubo
POSTGRES_DB=nubo
PGADMIN_EMAIL=admin@nubo.com
PGADMIN_PASSWORD=ULTRA_LONG_RANDOM_PASSWORD

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=nubo-bucket
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# L'URL que l'application mobile utilisera (passe par Nginx)
# En local, on utilise l'IP de ton PC ou localhost si tu es sur simulateur
WATERMARK_API_URL=https://localhost

# La clé secrète partagée (Doit être la même dans les deux services)
WATERMARK_SECRET_KEY=cle_secrete_de_test_nubo_2026

# DSN Postgres (Pour GORM ou SQLx)
DB_DSN=host=postgres user=nubo password=nubo dbname=nubo port=5432 sslmode=disable


# --- MONGO ---
MONGO_DB=nubo
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=ULTRA_LONG_RANDOM_PASSWORD
MONGO_UI_USER=admin
MONGO_UI_PASSWORD=ULTRA_LONG_RANDOM_PASSWORD

# --- REDIS ---
REDIS_ADDR=redis:6379
REDIS_MAXMEMORY=4gb
REDIS_CONTAINER_LIMIT=4.5gb
REDIS_PASSWORD=ton_mot_de_passe_securise
REDIS_UI_USER=admin
REDIS_UI_PASSWORD=ULTRA_LONG_RANDOM_PASSWORD